{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/budget-response/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/budget-response/[token]"
		},
		{
			"src": "^/budgets/?(?:/__data.json)?$",
			"dest": "/(app)/budgets"
		},
		{
			"src": "^/budgets/new/?(?:/__data.json)?$",
			"dest": "/(app)/budgets/new"
		},
		{
			"src": "^/budgets/([^/]+?)/preview/?(?:/__data.json)?$",
			"dest": "/(app)/budgets/[id]/preview"
		},
		{
			"src": "^/budgets/([^/]+?)/update/?(?:/__data.json)?$",
			"dest": "/(app)/budgets/[budget_id]/update"
		},
		{
			"src": "^/dashboard/?(?:/__data.json)?$",
			"dest": "/(app)/dashboard"
		},
		{
			"src": "^/dogs/?(?:/__data.json)?$",
			"dest": "/(app)/dogs"
		},
		{
			"src": "^/dogs/new/?(?:/__data.json)?$",
			"dest": "/(app)/dogs/new"
		},
		{
			"src": "^/dogs/([^/]+?)/update/?(?:/__data.json)?$",
			"dest": "/(app)/dogs/[dog_id]/update"
		},
		{
			"src": "^/logout/?(?:/__data.json)?$",
			"dest": "/logout"
		},
		{
			"src": "^/raw-materials/?(?:/__data.json)?$",
			"dest": "/(app)/raw-materials"
		},
		{
			"src": "^/raw-materials/new/?(?:/__data.json)?$",
			"dest": "/(app)/raw-materials/new"
		},
		{
			"src": "^/raw-materials/([^/]+?)/update/?(?:/__data.json)?$",
			"dest": "/(app)/raw-materials/[raw_material_id]/update"
		},
		{
			"src": "^/recipes/?(?:/__data.json)?$",
			"dest": "/(app)/recipes"
		},
		{
			"src": "^/recipes/new/?(?:/__data.json)?$",
			"dest": "/(app)/recipes/new"
		},
		{
			"src": "^/recipes/([^/]+?)/update/?(?:/__data.json)?$",
			"dest": "/(app)/recipes/[recipe_id]/update"
		},
		{
			"src": "^/settings/?(?:/__data.json)?$",
			"dest": "/(app)/settings"
		},
		{
			"src": "^/tutors/?(?:/__data.json)?$",
			"dest": "/(app)/tutors"
		},
		{
			"src": "^/tutors/new/?(?:/__data.json)?$",
			"dest": "/(app)/tutors/new"
		},
		{
			"src": "^/tutors/([^/]+?)/update/?(?:/__data.json)?$",
			"dest": "/(app)/tutors/[tutor_id]/update"
		},
		{
			"src": "^/veterinaries/?(?:/__data.json)?$",
			"dest": "/(app)/veterinaries"
		},
		{
			"src": "^/veterinaries/new/?(?:/__data.json)?$",
			"dest": "/(app)/veterinaries/new"
		},
		{
			"src": "^/veterinaries/([^/]+?)/update/?(?:/__data.json)?$",
			"dest": "/(app)/veterinaries/[veterinary_id]/update"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}